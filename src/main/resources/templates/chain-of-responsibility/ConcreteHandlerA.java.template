${PACKAGE_DECL}

/** Concrete handler — accepts requests starting with {@code "AUTH:"}. */
public final class Auth${TYPE_NAME}Handler extends ${TYPE_NAME}Handler {

    @Override
    public String handle(String request) {
        if (request.startsWith("AUTH:")) {
            return "[Auth] " + request.substring(5);
        }
        return super.handle(request);
    }
}
